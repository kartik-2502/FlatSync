# =========================================================================
# Rent & Flatmate Finder Root Configuration Template
# Copy this template to backend/.env and populate it with your keys.
# =========================================================================

# The port where the backend server will run
PORT=5000

# Secret key used for signing JSON Web Tokens (JWT) for authentication
JWT_SECRET=your_jwt_signing_secret_here

# Google Gemini API key used for AI-based compatibility scoring.
# If omitted or left empty, the application will automatically fall back
# to a local rule-based matching engine without crashing.
GEMINI_API_KEY=YOUR_GOOGLE_GEMINI_API_KEY_HERE

# Optional SMTP configuration for sending real interest request emails.
# If left blank, Nodemailer will automatically spin up a test Ethereal.email SMTP
# server and print visual email preview URLs in the console for auditing.
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
